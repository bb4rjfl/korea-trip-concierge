# 외부 API 키 (실제 값은 .env에, 절대 커밋 금지). 발급법: docs/08, docs/12
# data.go.kr 단일 키 (TourAPI 다국어 + TAGO 버스 + 기상청 + 에어코리아 공용)
BUS_API_KEY=
TOUR_API_KEY=
# ODsay 대중교통 경로
TRANSIT_API_KEY=
# 서울 열린데이터광장 (지하철 실시간 등) 단일 키
SUBWAY_API_KEY=
# VisitJeju 제주관광
JEJU_API_KEY=
# 카카오 Local (REST 키만, 콘솔 카카오맵 ON 후) — 보류
KAKAO_REST_API_KEY=
# 네이버 지역검색 (식당/카페 포괄)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
# Foursquare Places (영어 POI)
FOURSQUARE_API_KEY=
# VisitSeoul (서울 음식/관광/쇼핑/숙박, 다국어) — 사이트명+URL 등록 후 발급
VISITSEOUL_API_KEY=
# 서버 포트 (Streamable HTTP)
PORT=8080
